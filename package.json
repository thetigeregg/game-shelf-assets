{
  "name": "game-shelf-assets",
  "version": "0.1.0",
  "private": true,
  "description": "Immutable third-party asset publisher for Game Shelf",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "node scripts/lint.mjs",
    "test": "vitest run",
    "build:manifests": "node scripts/generate-manifest.mjs --all",
    "artifact:fetch:emulatorjs": "node scripts/fetch-emulatorjs.mjs",
    "artifact:release:emulatorjs": "node scripts/release-emulatorjs.mjs --artifact emulatorjs",
    "verify:all": "node scripts/verify-manifest.mjs --all",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@thetigeregg/commitlint-config": "^0.4.5",
    "@thetigeregg/dev-cli": "^1.0.1",
    "@thetigeregg/lint-staged-config": "^0.2.5",
    "@thetigeregg/ncu-config": "^1.0.0",
    "@thetigeregg/prettier-config": "^0.3.5",
    "@types/node": "^24.12.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^20.0.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
